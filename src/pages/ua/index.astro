---
import Layout from '../../layouts/Layout.astro';
import { getDict } from '../../i18n/index.js';
import CursorBlob from '../../components/CursorBlob.jsx';
import Header from '../../components/Header.jsx';
import Hero from '../../components/Hero.jsx';
import Ticker from '../../components/Ticker.jsx';
import Case from '../../components/Case.jsx';
import Bio from '../../components/Bio.jsx';
import Program from '../../components/Program.jsx';
import Philosophy from '../../components/Philosophy.jsx';
import Voices from '../../components/Voices.jsx';
import FAQ from '../../components/FAQ.jsx';
import Finale from '../../components/Finale.jsx';
import Foot from '../../components/Foot.jsx';

const t = getDict('ua');
const lang = 'ua';

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": t.faq.items.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
});
---
<Layout meta={t.meta} lang={lang} canonicalPath="/ua/" faqSchema={faqSchema}>
  <div class="hud-grid"></div>
  <div class="hud-noise"></div>
  <CursorBlob client:load />
  <Header t={t} lang={lang} client:load />
  <Hero t={t} client:visible />
  <Ticker t={t} />
  <Case t={t} />
  <Bio t={t} />
  <Program t={t} />
  <Philosophy t={t} />
  <Voices t={t} />
  <FAQ t={t} client:visible />
  <Finale t={t} />
  <Foot t={t} />
</Layout>
